#file searching path

ifeq ($(cpu_ssd222d), yes)
    CROSS_COMPILE=arm-none-linux-gnueabihf-
else
    CROSS_COMPILE=mips-linux-gnu-
endif

CC=$(CROSS_COMPILE)gcc
LD=$(CROSS_COMPILE)ld
AR=$(CROSS_COMPILE)ar
RM=rm
CP=cp
MKBIN =$(SDK_INSTALL_DIR)/tools/BuildBin/BuildBin.exe

LIBPATH = $(SDK_LIB_DIR)
APIPATH = $(SDK_API_DIR)
LIBAPIPATH = libapi
OBJPATH = obj_err
SRCPATH = src
INCPATH = inc
BINPATH = bin
MKNLDPATH = bin
LIBJSONINC = libcJSON/inc
LIBJSONSRC = libcJSON/src

MQTT_INC_PATH = -ID:/xhh/1/tmpl/weather/lib/include
MQTT_LIB_PATH = -LD:/xhh/1/tmpl/weather/lib

CURL_INC_PATH = -ID:/iPaylabSDK/api/arm/sigmastar/2.0.0/syslib/include
CURL_LIB_PATH = -LD:/iPaylabSDK/api/arm/sigmastar/2.0.0/syslib/lib

# ??????
CFLAGS+= -W -Wall
DEFS = -DCONFIG_CPU_SSD222D

ifeq ($(cpu_ssd222d), yes)
CFLAGS+= $(DEFS)
endif

# ??????
ifeq ($(cpu_ssd222d), yes)
LDFLAGS = -L$(LIBPATH) -L$(SDK_SYS_LIB_DIR) $(MQTT_LIB_PATH) -lsdk  -lfreetype -lpng16 -lturbojpeg -ljpeg -lz -lcjson -lpthread -lsqlite3 
else
LDFLAGS = -L$(LIBPATH) -L$(SDK_SYS_LIB_DIR) $(MQTT_LIB_PATH) -lsdk  -lfreetype -lpng16 -lturbojpeg -ljpeg -lz -lcjson -lpthread -lsqlite3 -lCUDW -lm -lcurl -lmosquitto -lssl -lcrypto
endif


#??????
VPATH = $(SRCPATH) $(APIPATH) $(BINPATH) $(OBJPATH) $(LIBAPIPATH) $(SYSLIB_PATH) $(LIBJSONSRC)

#???????
INCLPATH = -I$(INCPATH) -I$(APIPATH) -I$(LIBAPIPATH) -I$(LIBJSONINC) $(CURL_INC_PATH) $(MQTT_INC_PATH)


# ???????
BINDIR = $(BINPATH)

# ??????
NAME = tmpl.bin
LIBFILE = 

# ????????
SRCS=$(wildcard $(SRCPATH)/*.c $(LIBJSONSRC)/*.c)
SRSS=$(notdir $(SRCS))
OBJS=$(subst .c,.o,$(SRSS))

OBJSD=		$(addprefix $(OBJPATH)/,$(SRSS))
OBJSY=		$(subst .c,.o,$(OBJSD))

SRCSSS=		$(wildcard $(APIPATH)/*.c)
SRSSSS=		$(notdir $(SRCSSS))
OBJSSS=		$(subst .c,.o,$(SRSSSS))

OBJSSSD=	$(subst $(APIPATH)/,$(OBJPATH)/,$(SRCSSS))
OBJSSSY=	$(subst .c,.o,$(OBJSSSD)) 

OBJS +=		$(OBJSSS)

#??????
.all: .config $(NAME)

$(NAME):$(OBJS) $(OBJSSS)
	$(CC) -o $(BINDIR)/$(NAME) $(OBJSY) $(OBJSSSY)  $(LDFLAGS) >$(OBJPATH)/link.err -g -funwind-tables -rdynamic -Wl,-Map=$(NAME).map 
	$(MKBIN) -o $(BINDIR)/tmpl.tpk -t $(BINDIR)/bintp.p1t -f $(BINDIR)/tpkfilelist.txt

#????????
.config: $(subst .o,.deps,$(OBJS)) 

%.o: %.c 
	$(CC) -c  $(CFLAGS) $(INCLPATH) $< -o  $(OBJPATH)/$(subst .c,.o,$@) >$(OBJPATH)/$(subst .o,.err,$@)
	
%.deps: %.c
	$(CC) -M $(INCLPATH) $< > $(OBJPATH)/$@ 

clean:
	-$(RM) -rf $(OBJPATH)/*.o $(OBJPATH)/*.deps

